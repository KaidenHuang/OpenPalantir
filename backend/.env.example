# ===== Neo4j Configuration =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# ===== Redis Configuration =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ===== Celery Configuration =====
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===== Application =====
APP_ENV=development
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:5175
BATCH_SIZE=100
CACHE_TTL=3600

# ===== LLM API Keys (Optional) =====
# OpenAI API Key
OPENAI_API_KEY=
# SiliconFlow API Key
SILICONFLOW_API_KEY=
# DeepSeek API Key
DEEPSEEK_API_KEY=
