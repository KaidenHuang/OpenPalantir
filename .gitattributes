# Auto detect text files and perform LF normalization
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Web
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Config files
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
.env.example text eol=lf
.editorconfig text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Shell scripts (require LF)
*.sh text eol=lf
*.ps1 text eol=crlf

# Binary files
*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary

# Windows batch files require CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
